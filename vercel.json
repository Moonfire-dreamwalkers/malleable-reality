{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/discord-server-directory",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/discord-server-directory",
      "permanent": true
    },
    {
      "source": "/spiritual-server-directory",
      "destination": "/discord-server-directory",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/discord-server-directory",
      "permanent": false
    },
    {
      "source": "/modules",
      "destination": "/discord-server-directory",
      "permanent": false
    },
    {
      "source": "/blog.html",
      "destination": "/discord-server-directory",
      "permanent": false
    },
    {
      "source": "/modules.html",
      "destination": "/discord-server-directory",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()"
        }
      ]
    }
  ]
}
